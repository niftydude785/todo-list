# PostgreSQL connection string from Supabase
# Found in: Supabase Dashboard > Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# A long random secret string for signing JWT tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Resend API key
# Found in: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The URL of your frontend (used in magic link emails)
# Local development: http://localhost:5173
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# Port the backend listens on (Render sets this automatically)
PORT=3001
