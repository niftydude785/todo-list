# PostgreSQL connection string from Supabase
# Found in: Supabase Dashboard > Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# A long random secret string for signing JWT tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Gmail sender — use a Gmail address and an App Password
# App Password: https://myaccount.google.com/apppasswords (requires 2FA enabled)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The URL of your frontend (used in confirmation email links)
# Local development: http://localhost:5173
# Production: https://your-frontend-domain.vercel.app
FRONTEND_URL=http://localhost:5173

# The URL of this backend (used in confirmation email links)
# Local development: http://localhost:3001
# Production: https://your-backend.onrender.com
BACKEND_URL=http://localhost:3001

# Port the backend listens on (Render sets this automatically)
PORT=3001
